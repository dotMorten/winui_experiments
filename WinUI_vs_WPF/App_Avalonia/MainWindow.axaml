<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:App_Avalonia"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="App_Avalonia.MainWindow"
        Title="App_Avalonia">
    <Grid Loaded="Grid_Loaded" RowDefinitions="*,Auto">
        <ListBox x:Name="MyListView" x:DataType="local:DataItem" ItemsSource="{CompiledBinding}" >
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="local:DataItem">
                    <TextBlock Text="{CompiledBinding Name}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <TextBlock Text="Loading" x:Name="status" Grid.Row="1" HorizontalAlignment="Right"/>
    </Grid>
</Window>
